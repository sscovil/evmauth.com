{
    "extends": "@evmauth/tsconfig/nextjs.json",
    "compilerOptions": {
        "paths": {
            "@/*": ["./src/*"]
        },
        "allowJs": true,
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
    "exclude": ["node_modules"]
}
